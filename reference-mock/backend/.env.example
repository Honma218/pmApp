# ローカル例: postgresql+psycopg://localhost/staff_report
DATABASE_URL=

# --- Google OAuth (ステップ3) ---
# Google Cloud Console > APIとサービス > 認証情報 で「OAuth クライアント ID」(種類: ウェブ
# アプリケーション) を作成し、承認済みリダイレクト URI に下記 OAUTH_REDIRECT_URI を登録する。
# 例: http://localhost:8000/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
# 設定すると、この末尾ドメインのメールのみログインを許可する（例: example.com）
ALLOWED_EMAIL_DOMAIN=
# セッション Cookie の署名鍵（本番では十分に長いランダム値を必ず設定）
SESSION_SECRET=
# ログイン成功後のリダイレクト先（フロントはステップ4）
POST_LOGIN_REDIRECT_URL=
# 本番(HTTPS)では true にして Secure Cookie を強制
COOKIE_SECURE=

# --- AI 要約 (ステップ6) ---
# 未設定なら決定的な stub（鍵不要）。実プロバイダは gemini / vertex（claude は後続）。
AI_PROVIDER=
AI_API_KEY=
# 使用モデル（未設定時はプロバイダ既定値。例: gemini-2.5-flash）
AI_MODEL=
